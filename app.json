{
  "expo": {
    "name": "Red Planet Resorts",
    "slug": "red-planet-resorts",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "redplanetresorts",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redplanetresorts.redplanetresorts",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "googleServicesFile": "./google-services.json",

      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },

      "predictiveBackGestureEnabled": false,
      "package": "com.redplanetresorts.redplanetresorts",

      "permissions": [
        "NOTIFICATIONS"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",

          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],

      "expo-font",
      "expo-image",
      "expo-web-browser",

      [
        "expo-notifications",
        {
          "icon": "./assets/images/notificationIcon.png",
          "color": "#ffffff"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},

      "eas": {
        "projectId": "04cfa4ab-7aff-4884-bf4e-8cdac57c4a0f"
      }
    },

    "owner": "virginworkzteam"
  }
}